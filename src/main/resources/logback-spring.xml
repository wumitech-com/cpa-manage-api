<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 日志存储路径 -->
    <property name="LOG_PATH" value="./logs"/>
    <property name="LOG_FILE" value="cpa-manage-api"/>
    
    <!-- 日志输出格式 - 普通格式（文件用） -->
    <property name="LOG_PATTERN" 
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{50} - [%method,%line] - %msg%n"/>
    
    <!-- 日志输出格式 - 彩色格式（控制台用） -->
    <property name="COLOR_LOG_PATTERN" 
              value="%yellow(%date{yyyy-MM-dd HH:mm:ss.SSS}) %highlight(%-5level) %cyan([%thread]) %boldMagenta(%logger{50}) - %highlight(%msg%n)"/>

    <!-- 控制台输出 - 彩色 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${COLOR_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- INFO级别日志文件 -->
    <appender name="FILE_INFO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE}.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 日志文件名格式 -->
            <fileNamePattern>${LOG_PATH}/${LOG_FILE}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 日志最大的历史 30天 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <!-- 过滤的级别：INFO及以上 -->
            <level>INFO</level>
        </filter>
    </appender>

    <!-- ERROR级别日志文件 -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE}-error.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 日志文件名格式 -->
            <fileNamePattern>${LOG_PATH}/${LOG_FILE}-error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 日志最大的历史 90天 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <!-- 只记录ERROR级别 -->
            <level>ERROR</level>
            <!-- 匹配时的操作：接收（记录） -->
            <onMatch>ACCEPT</onMatch>
            <!-- 不匹配时的操作：拒绝（不记录） -->
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>


    <!-- 异步输出 - 提高性能 -->
    <appender name="ASYNC_INFO" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 不丢失日志.默认的,如果队列的80%已满,则会丢弃TRACT、DEBUG、INFO级别的日志 -->
        <discardingThreshold>500</discardingThreshold>
        <neverBlock>true</neverBlock>
        <!-- 更改默认的队列的深度,该值会影响性能.默认值为256 -->
        <queueSize>20000</queueSize>
        <!-- 添加附加的appender,最多只能添加一个 -->
        <appender-ref ref="FILE_INFO"/>
    </appender>

    <appender name="ASYNC_ERROR" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 不丢失日志.默认的,如果队列的80%已满,则会丢弃TRACT、DEBUG、INFO级别的日志 -->
        <discardingThreshold>0</discardingThreshold>
        <!-- 更改默认的队列的深度,该值会影响性能.默认值为256 -->
        <queueSize>2000</queueSize>
        <!-- 添加附加的appender,最多只能添加一个 -->
        <appender-ref ref="FILE_ERROR"/>
    </appender>

    <!-- 系统模块日志级别控制 -->
    <logger name="com.cpa" level="info"/>
    
    <!-- 减少第三方框架日志输出 -->
    <logger name="org.springframework" level="warn"/>
    <logger name="org.apache" level="warn"/>
    <logger name="org.hibernate" level="warn"/>
    <logger name="com.zaxxer.hikari" level="warn"/>
    <logger name="io.lettuce" level="warn"/>
    <logger name="org.mybatis" level="warn"/>
    <logger name="com.baomidou" level="warn"/>
    <logger name="com.alibaba.druid" level="warn"/>

    <!-- 开发环境配置 -->
    <springProfile name="dev">
        <!-- 开发环境下com.cpa包使用DEBUG级别 -->
        <logger name="com.cpa" level="debug"/>
        <root level="info">
            <appender-ref ref="CONSOLE"/>  <!-- 控制台彩色输出 -->
            <appender-ref ref="ASYNC_INFO"/>
            <appender-ref ref="ASYNC_ERROR"/>
        </root>
    </springProfile>

    <!-- 生产环境配置 -->
    <springProfile name="prod">
        <!-- 生产环境下com.cpa包使用INFO级别 -->
        <logger name="com.cpa" level="info"/>
        <root level="info">
            <!-- 生产环境同时输出到控制台和文件 -->
            <appender-ref ref="CONSOLE"/>  <!-- 控制台彩色输出 -->
            <appender-ref ref="FILE_INFO"/>  <!-- 文件输出 -->
            <appender-ref ref="FILE_ERROR"/>  <!-- 错误日志文件输出 -->
        </root>
    </springProfile>

    <!-- 默认配置 -->
    <springProfile name="!dev &amp; !prod">
        <root level="info">
            <appender-ref ref="CONSOLE"/>  <!-- 控制台彩色输出 -->
            <appender-ref ref="ASYNC_INFO"/>
            <appender-ref ref="ASYNC_ERROR"/>
        </root>
    </springProfile>

</configuration>

